# Sentry error monitoring (optional — app works without it)
VITE_SENTRY_DSN=

# Supabase backend (optional — app works offline without these)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI narration gateway (optional — combat narrates deterministically without it).
# The browser posts a resolved-round summary to this same-origin path; the server
# function holds the key and calls Claude. Default Netlify path shown.
VITE_AI_NARRATE_ENDPOINT=/.netlify/functions/ai-narrate

# Server-only (set in the Netlify environment, NOT VITE_-prefixed — never shipped
# to the browser). Both must be set to enable LLM narration; otherwise the gateway
# returns 503 and the client uses its deterministic narrator.
#   ANTHROPIC_API_KEY  — your Anthropic API key.
#   ANTHROPIC_MODEL    — a current Claude model id (see Anthropic's model list).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
