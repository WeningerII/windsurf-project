# Sentry error monitoring (optional — app works without it)
VITE_SENTRY_DSN=

# Supabase backend (optional — app works offline without these)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI gateway (optional — app works fully without it; RFC 002)
# Build-time flag (browser): render AI affordances. Default off.
VITE_AI_ENABLED=
# SERVER-ONLY provider key for the Netlify function — NOT a VITE_ var, so it is
# never exposed in the browser bundle. Without it the gateway degrades to manual.
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional model override for the gateway (defaults to gemini-2.0-flash).
AI_GATEWAY_MODEL=
