# Sentry error monitoring (optional — app works without it)
VITE_SENTRY_DSN=

# Supabase backend (optional — app works offline without these)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI gateway (optional — app works fully without it; RFC 002)
# Build-time flag (browser): render AI affordances. Default off.
VITE_AI_ENABLED=
# SERVER-ONLY provider key for the Netlify function — NOT a VITE_ var, so it is
# never exposed in the browser bundle. Without it the gateway degrades to manual.
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional text-model override for the gateway (defaults to gemini-2.0-flash).
AI_GATEWAY_MODEL=
# Optional image-model override for illustrate-scene (defaults to imagen-4.0-fast-generate-001).
AI_IMAGE_MODEL=
# Provider selection: 'google' (default when a key is present) or 'mock' (a
# deterministic, key-less adapter for CI/local — exercises the live path).
AI_PROVIDER=
# Optional cost control: max gateway requests per client per window. Unset or
# <= 0 disables limiting (today's behavior). Exhaustion degrades to 429/manual.
AI_RATE_LIMIT=
# Rate-limit window length in milliseconds (defaults to 60000 when AI_RATE_LIMIT is set).
AI_RATE_LIMIT_WINDOW_MS=
