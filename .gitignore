# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
coverage
coverage-*/
*.local

# TypeScript incremental / project-reference build cache
*.tsbuildinfo

# Environment files (never commit secrets). Keep .env.example as the template.
.env
.env.*
!.env.example

# TypeDoc generated API docs
docs/api

# Report files
*-report.txt
spell-report.txt
playwright-report/
test-results/
# Transient per-run diagnostic from check:compute-register (Tier A vs A+B content
# differs per flag); the committed honest metric is docs/generated/roadmap-metrics.*.
docs/generated/compute-register-gate.json
# Transient per-run timings from the user-outcome harness; the committed floor is
# e2e/outcome/baseline.json.
e2e/outcome/last-run.json

# Repo-pinned Node runtime files and local runtime cache
.cache/node-dist/
.cache/node-runtime/

# Local scratch workspace for one-off scripts and notes
scratch/
.tmp/

# Local agent/tooling artifacts (never commit)
.codex
.aider*
.claude/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
stats.html
