# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
coverage
coverage-*/
*.local

# TypeScript incremental / project-reference build cache
*.tsbuildinfo

# Environment files (never commit secrets). Keep .env.example as the template.
.env
.env.*
!.env.example

# TypeDoc generated API docs
docs/api

# Report files
*-report.txt
spell-report.txt
playwright-report/
test-results/

# Repo-pinned Node runtime files and local runtime cache
.cache/node-dist/
.cache/node-runtime/

# Local scratch workspace for one-off scripts and notes
scratch/
.tmp/

# Local agent/tooling artifacts (never commit)
.codex
.aider*

# Claude Code: project settings and commands are shared; local state is not
.claude/*
!.claude/settings.json
!.claude/commands/

# Obsidian workspace state (repo root opens as a vault; per-user config stays local)
.obsidian/

# graphify: graph.json, labels, GRAPH_REPORT.md and wiki/ are committed shared
# memory. Bulky regenerable artifacts are not — rebuild with:
#   npm run graph:vault   (per-symbol Obsidian vault -> graphify-out/obsidian/)
#   graphify cluster-only .   (graph.html visualization)
graphify-out/cache/
graphify-out/graph.html
graphify-out/GRAPH_TREE.html
graphify-out/obsidian/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
stats.html
