{
  "name": "rpg-character-sheet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "node:check": "node scripts/check-node-version.mjs",
    "preinstall": "node scripts/check-node-version.mjs",
    "bootstrap:node": "node scripts/bootstrap-node.mjs",
    "pinned": "node scripts/run-with-pinned-node.mjs",
    "runtime:doctor": "node scripts/runtime-doctor.mjs",
    "build": "npm run node:check && tsc && npm run typecheck:netlify && vite build",
    "typecheck:netlify": "tsc -p tsconfig.netlify.json",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:doc-drift": "npm run node:check && tsx scripts/check-doc-drift.mjs",
    "check:generated-docs": "npm run node:check && node scripts/check-generated-docs.mjs",
    "check:repo-hygiene": "npm run node:check && node scripts/check-repo-hygiene.mjs",
    "check:dead-code": "npm run node:check && knip",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "record:verify-baseline": "npm run node:check && tsx scripts/record-verification-baseline.mjs",
    "test": "vitest",
    "test:ui": "npm run node:check && vitest --ui",
    "test:coverage": "npm run node:check && vitest --coverage",
    "test:e2e": "npm run node:check && node scripts/check-playwright-browsers.mjs && playwright test",
    "test:e2e:headed": "npm run node:check && node scripts/check-playwright-browsers.mjs && playwright test --headed",
    "test:e2e:ui": "npm run node:check && node scripts/check-playwright-browsers.mjs && playwright test --ui",
    "docs": "typedoc",
    "generate:spell": "tsx src/scripts/generators/generate-spell.ts",
    "generate:indexes": "tsx src/scripts/generators/generate-spell-indexes.ts",
    "generate:all-systems": "tsx src/scripts/generators/generate-all-system-indexes.ts",
    "roadmap:metrics": "npm run node:check && tsx src/scripts/generate-roadmap-metrics.ts",
    "progress": "tsx src/scripts/show-progress.ts",
    "validate": "npm run node:check && tsx src/scripts/validate-classes.ts",
    "enhance": "tsx src/scripts/enhance-classes.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "verify": "npm run node:check && npm run lint && npm run format:check && npm run test:coverage -- --run --maxWorkers=1 && npm run validate && npm run build && npm run check:bundle-size && npm run test:e2e && npm run check:repo-hygiene && npm run check:generated-docs && npm run check:doc-drift && npm run check:dead-code"
  },
  "dependencies": {
    "@sentry/browser": "^10.44.0",
    "@supabase/supabase-js": "^2.99.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.17",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.3.7",
    "knip": "^5.88.1",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.7.0",
    "typedoc": "^0.28.16",
    "typescript": "^5.2.2",
    "vite": "^7.3.2",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.17"
  }
}
